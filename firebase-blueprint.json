{
  "entities": {
    "User": {
      "title": "User",
      "description": "A CA firm user account",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "firmName": { "type": "string" },
        "adminName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "firmName", "adminName", "role", "createdAt"]
    },
    "DemoRequest": {
      "title": "Demo Request",
      "description": "A request for a demo",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "firmName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "firmName", "email", "phone", "date", "time", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the Gemini chatbot",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/demoRequests/{requestId}": {
      "schema": { "$ref": "#/entities/DemoRequest" },
      "description": "Demo requests collection"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat messages for a user"
    }
  }
}
